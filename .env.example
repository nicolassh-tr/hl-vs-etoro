# eToro chart API (first-party): GET {ETORO_CANDLE_HOST}/candles/asc.json/OneMinute/1440/{id}?client_request_id=…
# Find IDs: open etoro.com chart → DevTools → Network → candle.etoro.com → path …/2/{id}/…

# ETORO_CANDLE_HOST=https://candle.etoro.com

ETORO_INSTRUMENT_OIL=17
# ETORO_INSTRUMENT_NQ=
# ETORO_INSTRUMENT_GOLD=
# ETORO_INSTRUMENT_NATGAS=

# If an instrument ID is unset, /api/etoro/{name} falls back to legacy JSON under:
# ETORO_FUNCTIONS_BASE=https://sidekick-c26b0845.base44.app
